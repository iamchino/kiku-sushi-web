import { useRef } from "react";
import { Link } from "react-router-dom";
import { motion, useScroll, useTransform } from "framer-motion";
import { ChevronRight } from "lucide-react";
import heroProv from "@/assets/hero-prov.webp";
import heroProvMobile from "@/assets/hero-prov-mobile.webp";

/**
 * Hero minimal brutal:
 * - Imagen full-bleed (HEROPROV) con parallax — desktop horizontal, mobile crop vertical
 * - Cero texto. Solo 2 CTAs: Reservar (champagne, dominante) + Pedir (ghost)
 * - Overlay de legibilidad + grano sutil
 *
 * VIDEO EN STANDBY: el bloque de video queda comentado más abajo.
 * Cuando llegue el video definitivo, descomentalo y borrá el <picture>.
 * Los archivos siguen en /public/video/ (hero-loop, hero-loop-mobile).
 */
const HeroV2 = () => {
  const ref = useRef<HTMLElement>(null);
  const { scrollYProgress } = useScroll({
    target: ref,
    offset: ["start start", "end start"],
  });

  // Parallax
  const bgY = useTransform(scrollYProgress, [0, 1], ["0%", "30%"]);
  const bgScale = useTransform(scrollYProgress, [0, 1], [1, 1.15]);
  const contentY = useTransform(scrollYProgress, [0, 1], ["0%", "-30%"]);
  const contentOpacity = useTransform(scrollYProgress, [0, 0.6], [1, 0]);

  return (
    <section
      ref={ref}
      id="top"
      className="relative h-screen min-h-[640px] flex items-center justify-center overflow-hidden v2-bg-base"
    >
      {/* BG LAYER (con parallax) */}
      <motion.div
        style={{ y: bgY, scale: bgScale }}
        className="absolute inset-0 w-full h-[120%]"
      >
        {/* Imagen hero: mobile usa el crop vertical, desktop la horizontal */}
        <picture>
          <source media="(max-width: 768px)" srcSet={heroProvMobile} />
          <img
            src={heroProv}
            alt="Kiku Sushi — ambiente nocturno"
            className="absolute inset-0 w-full h-full object-cover"
          />
        </picture>

        {/* ── VIDEO EN STANDBY ──────────────────────────────────────
        Descomentá este bloque (y borrá el <picture> de arriba)
        cuando esté el video definitivo:

        <video
          className="absolute inset-0 w-full h-full object-cover"
          autoPlay muted loop playsInline preload="auto"
          poster="/video/hero-poster.webp"
          aria-hidden="true"
        >
          <source src="/video/hero-loop.webm" type="video/webm" />
          <source src="/video/hero-loop.mp4" type="video/mp4" />
        </video>
        ─────────────────────────────────────────────────────────── */}
      </motion.div>

      {/* Overlay para legibilidad: sutil arriba, denso abajo donde viven los CTAs */}
      <div className="absolute inset-0 bg-gradient-to-b from-v2-bg/25 via-transparent to-v2-bg/70" />

      {/* Noise texture (grano sutil) */}
      <div
        className="absolute inset-0 opacity-[0.06] mix-blend-overlay pointer-events-none"
        style={{
          backgroundImage: `url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.4'/%3E%3C/svg%3E")`,
        }}
      />

      {/* CTAs — único contenido del hero */}
      <motion.div
        style={{ y: contentY, opacity: contentOpacity }}
        className="relative z-10 px-6"
      >
        <motion.div
          initial={{ opacity: 0, y: 28 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ delay: 0.5, duration: 1.1, ease: [0.22, 1, 0.36, 1] }}
          className="flex flex-row flex-wrap gap-3 md:gap-4 justify-center"
        >
          <Link
            to="/reservar"
            className="group bg-v2-champagne text-v2-bg px-7 py-3.5 md:px-12 md:py-5 text-[10px] md:text-[12px] uppercase tracking-[0.32em] font-medium text-center hover:bg-v2-text hover:-translate-y-0.5 transition-all duration-400 inline-flex items-center justify-center gap-3"
          >
            Reservar mesa
            <ChevronRight className="w-3.5 h-3.5 md:w-4 md:h-4 group-hover:translate-x-1 transition-transform" />
          </Link>
          <Link
            to="/pedir"
            className="group bg-black/60 backdrop-blur-[2px] text-v2-text border border-v2-champagne/35 px-7 py-3.5 md:px-12 md:py-5 text-[10px] md:text-[12px] uppercase tracking-[0.32em] font-medium text-center hover:border-v2-champagne hover:text-v2-champagne hover:-translate-y-0.5 transition-all duration-400 inline-flex items-center justify-center gap-3"
          >
            Pedir
            <ChevronRight className="w-3.5 h-3.5 md:w-4 md:h-4 group-hover:translate-x-1 transition-transform" />
          </Link>
        </motion.div>
      </motion.div>
    </section>
  );
};

export default HeroV2;
